{
  "manifest_version": 3,
  "name": "Mordred",
  "version": "0.2.0",
  "description": "Mordred Browser Extension — chat, E2E-encrypted Slack, and Web3 wallet bridge to a local Mordred-Hermes agent.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mordred",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "a0.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:7788/*",
    "http://127.0.0.1:7788/*",
    "https://app.slack.com/*",
    "https://*.slack.com/*",
    "https://discord.com/*",
    "https://*.discord.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://app.slack.com/*",
        "https://*.slack.com/*"
      ],
      "js": [
        "a1.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://discord.com/*",
        "https://*.discord.com/*"
      ],
      "js": [
        "a2.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.slack.com/*",
        "https://*.slack.com/*"
      ],
      "js": [
        "a5.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://*/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "a3.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://*/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "a4.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/sign/index.html"
      ],
      "matches": [
        "https://*/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ]
}